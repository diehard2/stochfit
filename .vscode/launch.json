{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach C++ to Electron",
      "type": "cppvsdbg",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "symbolSearchPath": "${workspaceFolder}/build",
      "sourceFileMap": {
        "${workspaceFolder}": "${workspaceFolder}"
      }
    }
  ]
}
