{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure Windows Release",
      "type": "shell",
      "command": "cmake --preset windows",
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "Configure Windows Debug",
      "type": "shell",
      "command": "cmake --preset windows-debug",
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "Configure Linux/macOS Release",
      "type": "shell",
      "command": "cmake --preset default",
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "Configure Linux/macOS Debug",
      "type": "shell",
      "command": "cmake --preset debug",
      "problemMatcher": [],
      "options": { "cwd": "${workspaceFolder}" }
    }
  ]
}
