{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "default",
      "displayName": "Default Release (Linux/Mac)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/Release"
    },
    {
      "name": "debug",
      "displayName": "Debug (Linux/Mac)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows",
      "displayName": "Windows Release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/Release",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "${sourceDir}/env/tools/ninja.exe",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/env/cmake/MsvcEnvironment.cmake",
        "VCPKG_APPLOCAL_DEPS": "OFF",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "inherits": "windows",
      "binaryDir": "${sourceDir}/build/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-profile",
      "displayName": "Windows Profile (RelWithDebInfo + frame pointers for VTune)",
      "inherits": "windows",
      "binaryDir": "${sourceDir}/build/RelWithDebInfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "windows",
      "configurePreset": "windows"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug"
    },
    {
      "name": "windows-profile",
      "configurePreset": "windows-profile"
    }
  ]
}
