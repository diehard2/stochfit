{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "default",
      "displayName": "Default Release (Linux/Mac)",
      "inherits": "base"
    },
    {
      "name": "debug",
      "displayName": "Debug (Linux/Mac)",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows",
      "displayName": "Windows Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "${sourceDir}/tools/ninja.exe",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/MsvcEnvironment.cmake",
        "VCPKG_APPLOCAL_DEPS": "OFF"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "inherits": "windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "windows",
      "configurePreset": "windows"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug"
    }
  ]
}
